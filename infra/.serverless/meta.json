e.Arn\n            Id: taskQueueTarget\n\n  Outputs:\n    TodosTableName:\n      Value: !Ref TodosTable\n      Export:\n        Name: ${self:service}-${sls:stage}-TodosTableName\n\n    TodoEventBusName:\n      Value: !Ref TodoEventBus\n      Export:\n        Name: ${self:service}-${sls:stage}-TodoEventBusName\n\n    TodoEventBusArn:\n      Value: !GetAtt TodoEventBus.Arn\n      Export:\n        Name: ${self:service}-${sls:stage}-TodoEventBusArn\n\n    TaskQueueArn:\n      Value: !GetAtt TaskQueue.Arn\n      Export:\n        Name: ${self:service}-${sls:stage}-TaskQueueArn\n\n    TaskQueueUrl:\n      Value: !Ref TaskQueue\n      Export:\n        Name: ${self:service}-${sls:stage}-TaskQueueUrl\n\n    TaskQueueDLQArn:\n      Value: !GetAtt TaskQueueDLQ.Arn\n      Export:\n        Name: ${self:service}-${sls:stage}-TaskQueueDLQArn",
